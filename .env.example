# Vercel 部署时建议留空，前端将直接请求同域 /api
VITE_API_BASE_URL=

# 本地开发可配置 AI Gateway API Key；部署在 Vercel 上也可改用 VERCEL_OIDC_TOKEN
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=deepseek/deepseek-v3.2
CORS_ALLOW_ORIGIN=*

# off | redis
RATE_LIMIT_MODE=off
RATE_LIMIT_PER_IP_DAY=5
RATE_LIMIT_GLOBAL_DAY=100
RATE_LIMIT_PREFIX=rate

# Redis: use either REDIS_URL, or host/port/password below
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
