# Vercel 部署时建议留空，前端将直接请求同域 /api
VITE_API_BASE_URL=

DEEPSEEK_API_KEY=
CORS_ALLOW_ORIGIN=*

# off | redis
RATE_LIMIT_MODE=off
RATE_LIMIT_PER_IP_DAY=5
RATE_LIMIT_GLOBAL_DAY=50
RATE_LIMIT_PREFIX=rate

# Redis: use either REDIS_URL, or host/port/password below
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
